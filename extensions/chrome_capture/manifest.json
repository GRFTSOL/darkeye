{
  "manifest_version": 3,
  "name": "DarkEye Capture",
  "version": "1.2.2",
  "description": "Capture page content for DarkEye",
  "action": {
    "default_icon": "icons/logo.png",
    "default_title": "Capture Page",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "offscreen"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "*://javdb.com/*",
    "*://www.javdb.com/*",
    "*://www.javlibrary.com/*",
    "*://*.dmm.co.jp/*",
    "*://www.minnano-av.com/*",
    "*://javtxt.com/*",
    "*://www.javtxt.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://javdb.com/*",
        "*://www.javdb.com/*",
        "*://www.javlibrary.com/*"
      ],
      "js": [
        "content/popup_capture.js"
      ]
    },
    {
      "matches": [
        "*://javdb.com/*",
        "*://www.javdb.com/*"
      ],
      "js": [
        "content/sites/javdb.js"
      ]
    },
    {
      "matches": [
        "*://www.javlibrary.com/*"
      ],
      "js": [
        "content/sites/javlibrary.js"
      ]
    },
    {
      "matches": [
        "*://*.dmm.co.jp/*"
      ],
      "js": [
        "content/sites/fanza.js"
      ]
    },
    {
      "matches": [
        "*://www.minnano-av.com/*"
      ],
      "js": [
        "content/sites/minnano-scrape.js",
        "content/sites/minnano.js"
      ]
    },
    {
      "matches": [
        "*://javdb.com/*",
        "*://www.javdb.com/*",
        "*://www.javlibrary.com/*",
        "*://javtxt.com/*",
        "*://www.javtxt.com/*"
      ],
      "js": [
        "content/sites/sniffer.js"
      ],
      "css": [
        "content/style.css"
      ]
    }
  ]
}
